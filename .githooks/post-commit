#!/bin/bash
# Post-commit hook: URL校验修正 + Token动态注入 + 自动push + 重试
# 持久化版本：此文件在 .githooks/ 下被 git 跟踪

REPO_DIR="/home/z/my-project/XEngineer"
ENV_FILE="${REPO_DIR}/.env"
LOG_FILE="${REPO_DIR}/.git/push-error.log"

timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

if [ ! -f "$ENV_FILE" ]; then
    echo "[$(timestamp)] ERROR: .env 文件不存在，无法自动push" >> "$LOG_FILE"
    exit 1
fi

GITHUB_TOKEN=$(sed -n 's/^GITHUB_TOKEN[[:space:]]*=[[:space:]]*//p' "$ENV_FILE" | tr -d '\r')
GITHUB_USER=$(sed -n 's/^GITHUB_USER[[:space:]]*=[[:space:]]*//p' "$ENV_FILE" | tr -d '\r')
GITHUB_REPO=$(sed -n 's/^GITHUB_REPO[[:space:]]*=[[:space:]]*//p' "$ENV_FILE" | tr -d '\r')

if [ -z "$GITHUB_TOKEN" ] || [ -z "$GITHUB_USER" ] || [ -z "$GITHUB_REPO" ]; then
    echo "[$(timestamp)] ERROR: .env 中缺少 GitHub 配置，无法自动push" >> "$LOG_FILE"
    exit 1
fi

EXPECTED_FETCH_URL="https://github.com/${GITHUB_USER}/${GITHUB_REPO}.git"
EXPECTED_PUSH_URL="https://${GITHUB_USER}:${GITHUB_TOKEN}@github.com/${GITHUB_USER}/${GITHUB_REPO}.git"

CURRENT_PUSH_URL=$(git remote get-url --push origin 2>/dev/null)
CURRENT_FETCH_URL=$(git remote get-url origin 2>/dev/null)

URL_CORRECTED=0

if [ "$CURRENT_FETCH_URL" != "$EXPECTED_FETCH_URL" ]; then
    git remote set-url origin "$EXPECTED_FETCH_URL"
    echo "[$(timestamp)] INFO: fetch URL 已修正" >> "$LOG_FILE"
    URL_CORRECTED=1
fi

if [ "$CURRENT_PUSH_URL" != "$EXPECTED_PUSH_URL" ]; then
    git remote set-url --push origin "$EXPECTED_PUSH_URL"
    echo "[$(timestamp)] INFO: push URL 已修正" >> "$LOG_FILE"
    URL_CORRECTED=1
fi

if [ "$URL_CORRECTED" -eq 0 ]; then
    echo "[$(timestamp)] INFO: remote URL 校验通过" >> "$LOG_FILE"
fi

PUSH_URL="https://${GITHUB_USER}:${GITHUB_TOKEN}@github.com/${GITHUB_USER}/${GITHUB_REPO}.git"

echo "[$(timestamp)] INFO: 开始自动push..." >> "$LOG_FILE"

if git push "$PUSH_URL" HEAD >> "$LOG_FILE" 2>&1; then
    echo "[$(timestamp)] INFO: push 成功" >> "$LOG_FILE"
else
    echo "[$(timestamp)] ERROR: push 失败，3秒后重试..." >> "$LOG_FILE"
    echo "[$(timestamp)] ERROR: push 失败，3秒后重试..." >&2
    sleep 3
    if git push "$PUSH_URL" HEAD >> "$LOG_FILE" 2>&1; then
        echo "[$(timestamp)] INFO: 重试push成功" >> "$LOG_FILE"
    else
        echo "[$(timestamp)] ERROR: 重试仍失败" >> "$LOG_FILE"
        echo "[$(timestamp)] ERROR: 重试仍失败" >&2
    fi
fi
